# 이 파일을 복사해서 .env로 만들고 설정값을 수정하세요
# 명령어: cp .env.example .env

# ── 로컬 DB (여주) ──
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# ── 원격 DB (부산) ──
DB_REMOTE_ENABLED=true
DB_REMOTE_HOST=
DB_REMOTE_PORT=
DB_REMOTE_NAME=
DB_REMOTE_USER=
DB_REMOTE_PASSWORD=

BOX_HEATPUMP_COUNT=4
BOX_UNDERGROUND_COUNT=10
MODBUS_TCP_PORT=8899
MODBUS_TCP_TIMEOUT=3

POWER_METER_COUNT=5

COLLECTION_INTERVAL=60

LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

APP_NAME=센서 모니터링 시스템
APP_VERSION=1.0.0
